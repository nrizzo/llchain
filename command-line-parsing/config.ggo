version	"0.0.1"
package	"clc-viz"
purpose	"Simple visualization of optimal colinear chaining recursive scores"
usage	"clc-viz [-n ANCHORNUM] [-g gap-gap.bmp]"

option	"anchors"		n	"Number of anchors"	long	typestr = "ANCHORNUM"	default = "3"	optional
option	"gap-gap-output-file"	g	"Visualize the gap-gap case in this file (BMP format)"	string	typestr = "BMPFILE"	default="gap-gap.bmp"	optional
option	"random-seed"	r	"Seed for the PRNG (-1 is different at every invocation)"	int	typestr = "INT"	default="-1"	optional

